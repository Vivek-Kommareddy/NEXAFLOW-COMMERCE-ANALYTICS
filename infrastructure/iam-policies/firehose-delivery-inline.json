{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowWriteToCommerceBucket",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetBucketLocation",
        "s3:GetObject",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::vivek-commerce-analytics-demo-2026",
        "arn:aws:s3:::vivek-commerce-analytics-demo-2026/*"
      ]
    }
  ]
}
